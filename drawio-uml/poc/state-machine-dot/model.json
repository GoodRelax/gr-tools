    {"source": "c_init", "target": "ModelWorld", "arrow": "transition"},
    {"source": "ModelWorld", "target": "ModelGoal", "arrow": "transition"},
    {"source": "ModelGoal", "target": "plan", "arrow": "transition", "label": "goal set"},
    {"source": "p_init", "target": "Simulate", "arrow": "transition"},
    {"source": "Simulate", "target": "Evaluate", "arrow": "transition", "label": "predict"},
    {"source": "Evaluate", "target": "Simulate", "arrow": "transition"},
    {"source": "plan", "target": "Execute", "arrow": "transition", "label": "plan found"},
    {"source": "Execute", "target": "Diagnose", "arrow": "transition", "label": "observe"},
    {"source": "Diagnose", "target": "consider", "arrow": "transition", "label": "re-model / re-plan"},
    {"source": "solving", "target": "LevelCleared", "arrow": "transition", "label": "win"},
    {"source": "solving", "target": "GameOver", "arrow": "transition", "label": "over"},
    {"source": "LevelCleared", "target": "solving", "arrow": "transition", "label": "next level (carry WM)"},
    {"source": "LevelCleared", "target": "Done", "arrow": "transition", "label": "all cleared"},
    {"source": "GameOver", "target": "Done", "arrow": "transition", "label": "no lives"},
    {"source": "Done", "target": "end", "arrow": "transition"}
