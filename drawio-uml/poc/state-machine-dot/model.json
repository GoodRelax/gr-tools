{
  "title": "GR-ARC-3 Agent Lifecycle (state machine)",
  "options": {"direction": "column", "node_separation": 0.8, "rank_separation": 1.4, "column_width": 220},
  "nodes": [
    {"name": "boot", "shape": "initial"},
    {"name": "Loading", "shape": "state", "description": "AssetLoader loads the baked deck (LTM: Lexicon.base / GoalPatterns / role priors), read-only. WM empty."},
    {"name": "NewGame", "shape": "state", "description": "Receive the first frame; init working memory (cleared per game)."},
    {"name": "s_init", "shape": "initial"},
    {"name": "Explore", "shape": "state", "description": "perceive: probing actions, collect TurnRecord/Probe, segment objects."},
    {"name": "c_init", "shape": "initial"},
    {"name": "ModelWorld", "shape": "state", "description": "induce/refine WorldModel (InteractionRule, StateAbstraction); verified free on the in-house sim."},
    {"name": "ModelGoal", "shape": "state", "description": "infer GoalPredicate (GoalPatterns instantiate + first-win bootstrap)."},
    {"name": "p_init", "shape": "initial"},
    {"name": "Simulate", "shape": "state", "description": "predict one step via WorldModel.predict (in-house sim) -- RHAE-free look-ahead."},
    {"name": "Evaluate", "shape": "state", "description": "goal-test + heuristic; expand the search, or stop when a winning line is found."},
    {"name": "Execute", "shape": "state", "description": "act: MPC -- commit ONE GameMove -> Action (the only RHAE cost); observe."},
    {"name": "Diagnose", "shape": "state", "description": "check prediction vs observation at the first divergence; route back to the wrong layer (re-explore / re-model / re-plan)."},
    {"name": "LevelCleared", "shape": "state", "description": "Outcome=win; carry-forward the WorldModel to the next level."},
    {"name": "GameOver", "shape": "state", "description": "Outcome=over (lives out)."},
    {"name": "Done", "shape": "state", "description": "is_done: scorecard exhausted / wall-clock out. (next game -> NewGame, omitted.)"},
    {"name": "end", "shape": "final"}
  ],
  "edges": [
    {"source": "boot", "target": "Loading", "arrow": "transition"},
    {"source": "Loading", "target": "NewGame", "arrow": "transition", "label": "loaded"},
    {"source": "NewGame", "target": "solving", "arrow": "transition", "label": "first frame"},
    {"source": "s_init", "target": "Explore", "arrow": "transition"},
