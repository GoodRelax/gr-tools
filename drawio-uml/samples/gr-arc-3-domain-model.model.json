{
 "title": "GR-ARC-3 Domain Model",
 "options": {
  "direction": "TB",
  "node_separation": 0.85,
  "rank_separation": 1.3,
  "column_width": 300
 },
 "nodes": [
  {
   "name": "Conception",
   "shape": "class",
   "stereotype": "answer",
   "attributes": [
    "world : WorldModel",
    "goal : GoalPredicate",
    "plan : GamePlan",
    "score : float",
    "status : active|committed|retired"
   ]
  },
  {
   "name": "WorldModel",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "rules : InteractionRule[*]",
    "pi : PiStateAbstraction",
    "impl : Symbolic|Learned|Graph"
   ],
   "methods": [
    "predict(state, move) : (MarkovState, win?)"
   ]
  },
  {
   "name": "GoalPredicate",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "kind : Atom|AND|OR|SEQUENCE",
    "children : GoalPredicate[*]  (ordered for SEQUENCE)",
    "condition : quantified over objects  (Profile & Relation)",
    "status : provisional|confirmed"
   ],
   "methods": [
    "test(state) : bool"
   ]
  },
  {
   "name": "GamePlan",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "steps : Step[*]  (ordered)",
    "horizon : int"
   ]
  },
  {
   "name": "Step",
   "shape": "class",
   "stereotype": "value",
   "attributes": [
    "move : GameMove",
    "expect : MarkovState",
    "servesSubGoal : GoalPredicate"
   ]
  },
  {
   "name": "PiStateAbstraction",
   "shape": "class",
   "stereotype": "function pi",
   "attributes": [
    "selects : salient objects, features & relations"
   ],
   "methods": [
    "project(Frame) : MarkovState"
   ]
  },
  {
   "name": "InteractionRule",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "trigger : objects + relations",
    "effect : object config",
    "confidence"
   ]
  },
  {
   "name": "MarkovState",
   "shape": "class",
   "stereotype": "value",
   "attributes": [
    "objects : role -> salient Profile",
    "relations : salient Relation holds"
   ],
   "methods": [
    "hash() : int"
   ]
  },
  {
   "name": "GoalPatterns",
   "shape": "class",
   "stereotype": "baked prior",
   "attributes": [
    "templates over object roles & relations"
   ],
   "methods": [
    "instantiate(objects) : GoalPredicate"
   ]
  },
  {
   "name": "TurnRecord",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "played : GameMove",
    "frames : Frame[*]"
   ]
  },
  {
   "name": "Probe",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "moves : GameMove[*]",
    "expected_observation"
   ]
  },
  {
   "name": "GameMove",
   "shape": "class",
   "stereotype": "value",
   "attributes": [
    "kind",
    "params (coords?)"
   ]
  },
  {
   "name": "Action",
   "shape": "class",
   "stereotype": "boundary (API)",
   "attributes": [
    "raw : ARC action (enum / x,y)"
   ]
  },
  {
   "name": "GameObject",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "id",
    "cells",
    "parts : sub-objects  (composite)",
    "profile : Profile"
   ]
  },
  {
   "name": "Profile",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "entries : DimId -> (value, conf)"
   ],
   "methods": [
    "render(lexicon) : name"
   ]
  },
  {
   "name": "Lexicon",
   "shape": "class",
   "stereotype": "entity",
   "attributes": [
    "base : Dimension + Relation[*]  (LTM)",
    "overlay : Dimension + Relation[*]  (WM)"
   ],
   "methods": [
    "get(id)",
    "extend(feature)"
   ]
  },
  {
   "name": "Dimension",
   "shape": "class",
   "stereotype": "unary feature",
   "attributes": [
    "id",
    "detector : object -> value",
    "domain",
    "rank"
   ]
  },
  {
   "name": "Relation",
   "shape": "class",
   "stereotype": "n-ary feature",
   "attributes": [
    "id",
    "arity : n",
    "detector : objects -> value/bool",
    "domain"
   ]
  }
 ],
