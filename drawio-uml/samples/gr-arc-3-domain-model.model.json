{
  "options": {
    "rankdir": "TB", "node_separation": 0.85, "rank_separation": 1.3, "column_width": 300,
    "layout": {"rows": [["input", "consider", "output"], ["vocabulary"]]},
    "clusters": {
      "input":      {"label": "Input port — perception (perceive)", "stroke": "#2F8FA8", "fill": "#E3F2F5"},
      "consider":   {"label": "Consider — the Conception (decide)", "stroke": "#9673A6", "fill": "#EDE7F6"},
      "output":     {"label": "Output port — action (act)", "stroke": "#D79B00", "fill": "#FFF0DD"},
      "vocabulary": {"label": "Vocabulary — Lexicon (Dimensions + Relations)", "stroke": "#82B366", "fill": "#E7F4E7"}
    }
  },
  "nodes": [
    {"name": "Conception", "shape": "class", "stereotype": "answer", "cluster": "consider",
     "attributes": ["world : WorldModel", "goal : GoalPredicate", "plan : GamePlan", "score : float", "status : active|committed|retired"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "WorldModel", "shape": "class", "stereotype": "entity", "cluster": "consider",
     "attributes": ["rules : InteractionRule[*]", "pi : PiStateAbstraction", "impl : Symbolic|Learned|Graph"],
     "methods": ["predict(state, move) : (MarkovState, win?)"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "GoalPredicate", "shape": "class", "stereotype": "entity", "cluster": "consider",
     "attributes": ["kind : Atom|AND|OR|SEQUENCE", "children : GoalPredicate[*]  (ordered for SEQUENCE)", "condition : quantified over objects  (Profile & Relation)", "status : provisional|confirmed"],
     "methods": ["test(state) : bool"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "GamePlan", "shape": "class", "stereotype": "entity", "cluster": "consider",
     "attributes": ["steps : Step[*]  (ordered)", "horizon : int"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "Step", "shape": "class", "stereotype": "value", "cluster": "consider",
     "attributes": ["move : GameMove", "expect : MarkovState", "servesSubGoal : GoalPredicate"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "PiStateAbstraction", "shape": "class", "stereotype": "function pi", "cluster": "consider",
     "attributes": ["selects : salient objects, features & relations"],
     "methods": ["project(Frame) : MarkovState"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "InteractionRule", "shape": "class", "stereotype": "entity", "cluster": "consider",
     "attributes": ["trigger : objects + relations", "effect : object config", "confidence"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "MarkovState", "shape": "class", "stereotype": "value", "cluster": "consider",
     "attributes": ["objects : role -> salient Profile", "relations : salient Relation holds"],
     "methods": ["hash() : int"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},
    {"name": "GoalPatterns", "shape": "class", "stereotype": "baked prior", "cluster": "consider",
     "attributes": ["templates over object roles & relations"],
     "methods": ["instantiate(objects) : GoalPredicate"],
     "fill": "#EDE7F6", "stroke": "#9673A6"},

    {"name": "TurnRecord", "shape": "class", "stereotype": "entity", "cluster": "input",
     "attributes": ["played : GameMove", "frames : Frame[*]"],
     "fill": "#E3F2F5", "stroke": "#2F8FA8"},
    {"name": "Probe", "shape": "class", "stereotype": "entity", "cluster": "input",
     "attributes": ["moves : GameMove[*]", "expected_observation"],
     "fill": "#E3F2F5", "stroke": "#2F8FA8"},

    {"name": "GameMove", "shape": "class", "stereotype": "value", "cluster": "output",
     "attributes": ["kind", "params (coords?)"],
     "fill": "#FFF0DD", "stroke": "#D79B00"},
    {"name": "Action", "shape": "class", "stereotype": "boundary (API)", "cluster": "output",
     "attributes": ["raw : ARC action (enum / x,y)"],
     "fill": "#FFF0DD", "stroke": "#D79B00"},

    {"name": "GameObject", "shape": "class", "stereotype": "entity", "cluster": "vocabulary",
     "attributes": ["id", "cells", "parts : sub-objects  (composite)", "profile : Profile"],
     "fill": "#E7F4E7", "stroke": "#82B366"},
    {"name": "Profile", "shape": "class", "stereotype": "entity", "cluster": "vocabulary",
     "attributes": ["entries : DimId -> (value, conf)"],
     "methods": ["render(lexicon) : name"],
     "fill": "#E7F4E7", "stroke": "#82B366"},
    {"name": "Lexicon", "shape": "class", "stereotype": "entity", "cluster": "vocabulary",
     "attributes": ["base : Dimension + Relation[*]  (LTM)", "overlay : Dimension + Relation[*]  (WM)"],
     "methods": ["get(id)", "extend(feature)"],
     "fill": "#E7F4E7", "stroke": "#82B366"},
    {"name": "Dimension", "shape": "class", "stereotype": "unary feature", "cluster": "vocabulary",
     "attributes": ["id", "detector : object -> value", "domain", "rank"],
     "fill": "#E7F4E7", "stroke": "#82B366"},
    {"name": "Relation", "shape": "class", "stereotype": "n-ary feature", "cluster": "vocabulary",
     "attributes": ["id", "arity : n", "detector : objects -> value/bool", "domain"],
     "fill": "#E7F4E7", "stroke": "#82B366"}
  ],
